{
  "name": "school-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "check": "tsc -b",
    "preview": "npm run build && vite preview",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply school-platform-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply school-platform-db --remote",
    "db:seed": "wrangler d1 execute school-platform-db --local --file=./seeds/seed.sql",
    "db:seed:remote": "wrangler d1 execute school-platform-db --remote --file=./seeds/seed.sql",
    "db:reset": "rm -rf .wrangler/state && npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^6.30.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.7.0",
    "@cloudflare/workers-types": "^4.20250610.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "wrangler": "^4.20.0"
  }
}
